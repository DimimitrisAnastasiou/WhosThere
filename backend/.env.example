# ── Database ──────────────────────────────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from Supabase → Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── Google Places ─────────────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development        # development | production
SECRET_KEY=change_this_to_a_random_secret_string
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000
